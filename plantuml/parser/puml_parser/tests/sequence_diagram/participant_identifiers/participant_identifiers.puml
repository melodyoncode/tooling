@startuml participant_identifiers

' normal participant declaration
actor "External User" as User
participant Service as "Sample Service"
boundary Gateway as GatewayAlias
control Controller
queue "Work Queue"

' create participant declaration
create participant "Created Worker" as Worker

' participant declaration with stereotype and order
participant LastOrder <<component>>  order 1

@enduml
